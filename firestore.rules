rules_version = '2';

// Permission model (see docs/access.md):
//   bishopric = bishop + 2 counselors        -> approve, edit, view
//   clerk     = exec sec / clerk (+ assts)   -> edit, view
// Every path checks the auth'd user has an active member doc in the target ward.
// Member-doc creation requires an existing active bishopric, so an empty ward
// can only be seeded by the Admin SDK (which bypasses these rules).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function memberPath(wardId, uid) {
      return /databases/$(database)/documents/wards/$(wardId)/members/$(uid);
    }

    function getMember(wardId, uid) {
      return get(memberPath(wardId, uid)).data;
    }

    function memberExists(wardId, uid) {
      return exists(memberPath(wardId, uid));
    }

    function isActiveMember(wardId) {
      return isSignedIn()
        && memberExists(wardId, request.auth.uid)
        && getMember(wardId, request.auth.uid).active == true;
    }

    function isActiveBishopric(wardId) {
      return isActiveMember(wardId)
        && getMember(wardId, request.auth.uid).role == 'bishopric';
    }

    // Status may stay the same, flip to 'draft' (the edit-invalidates-approvals
    // path), or progress to pending_approval / approved / published -- the
    // latter three only by bishopric.
    function statusTransitionOk(wardId) {
      return request.resource.data.status == resource.data.status
        || request.resource.data.status == 'draft'
        || isActiveBishopric(wardId);
    }

    // Approvals array may keep the same length (content edit or in-place
    // invalidation flip) OR grow by exactly one entry authored by the
    // bishopric member performing the write. Shrinking and foreign-author
    // appends are rejected. Duplicate prevention is client-enforced.
    function approvalsArrayOk(wardId) {
      let oldApprovals = resource.data.get('approvals', []);
      let newApprovals = request.resource.data.get('approvals', []);
      let lastIdx = newApprovals.size() - 1;
      return newApprovals.size() == oldApprovals.size()
        || (newApprovals.size() == oldApprovals.size() + 1
            && isActiveBishopric(wardId)
            && newApprovals[lastIdx].uid == request.auth.uid
            && newApprovals[lastIdx].invalidated == false);
    }

    match /wards/{wardId} {
      allow read: if isActiveMember(wardId);
      allow update: if isActiveMember(wardId);
      // Ward creation/deletion is Admin-SDK-only (see scripts/bootstrap-ward.ts).
      allow create, delete: if false;

      // Per-doc (get) + list access for members in a specific ward.
      match /members/{memberId} {
        allow read: if isActiveMember(wardId);
        // Only an existing active bishopric member can mutate the roster.
        // With no active bishopric in a ward, non-admin creates are blocked
        // -- the Admin SDK seeds the first member.
        allow create, update, delete: if isActiveBishopric(wardId);
      }

      // Meetings and their speaker subcollection. Content edits are open to
      // any active member. Approval transitions (status pending_approval /
      // approved, growing the approvals array) are gated to bishopric.
      match /meetings/{date} {
        allow read: if isActiveMember(wardId);
        allow create, delete: if isActiveMember(wardId);
        allow update: if isActiveMember(wardId)
          && statusTransitionOk(wardId)
          && approvalsArrayOk(wardId);

        match /speakers/{speakerId} {
          allow read: if isActiveMember(wardId);
          allow create, update, delete: if isActiveMember(wardId);
        }
      }

      // Letter templates: any active member can read; only bishopric can
      // edit (same rationale as member roster -- a ward-wide configuration
      // that clerks shouldn't unilaterally change).
      match /letterTemplates/{templateId} {
        allow read: if isActiveMember(wardId);
        allow create, update, delete: if isActiveBishopric(wardId);
      }
    }

    // Cross-ward allowlist query: any signed-in user can read a member doc
    // whose email matches their Google-verified email. This satisfies the
    // sign-in collectionGroup('members').where('email','==',auth.email)
    // lookup without letting them read unrelated members. The client must
    // filter on email for Firestore to consider the list query safe.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.email == userEmail();
    }

    // Deny-all baseline for every other path; permissions land in later phases.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
