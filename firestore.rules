rules_version = '2';

// Permission model (see docs/access.md):
//   bishopric = bishop + 2 counselors        -> approve, edit, view
//   clerk     = exec sec / clerk (+ assts)   -> edit, view
// Every path checks the auth'd user has an active member doc in the target ward.
// Member-doc creation requires an existing active bishopric, so an empty ward
// can only be seeded by the Admin SDK (which bypasses these rules).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function memberPath(wardId, uid) {
      return /databases/$(database)/documents/wards/$(wardId)/members/$(uid);
    }

    function getMember(wardId, uid) {
      return get(memberPath(wardId, uid)).data;
    }

    function memberExists(wardId, uid) {
      return exists(memberPath(wardId, uid));
    }

    function isActiveMember(wardId) {
      return isSignedIn()
        && memberExists(wardId, request.auth.uid)
        && getMember(wardId, request.auth.uid).active == true;
    }

    function isActiveBishopric(wardId) {
      return isActiveMember(wardId)
        && getMember(wardId, request.auth.uid).role == 'bishopric';
    }

    // Status may stay the same, flip to 'draft' (the edit-invalidates-approvals
    // path), or progress to pending_approval / approved / published -- the
    // latter three only by bishopric.
    function statusTransitionOk(wardId) {
      return request.resource.data.status == resource.data.status
        || request.resource.data.status == 'draft'
        || isActiveBishopric(wardId);
    }

    // Each existing approval must survive the write intact at the same
    // index: identity fields (uid / email / displayName /
    // approvedVersionHash) preserved, and the only permitted mutation is
    // `invalidated` flipping false → true (the edit-invalidates-approvals
    // path). Firestore rules don't support list comprehensions, so we
    // unroll positionally for the bounded list length (max 2 approvals).
    function approvalEntryPreserved(o, n) {
      return n.uid == o.uid
        && n.email == o.email
        && n.displayName == o.displayName
        && n.approvedVersionHash == o.approvedVersionHash
        && (n.invalidated == o.invalidated
            || (o.invalidated == false && n.invalidated == true));
    }

    function noApprovalTampering(oldA, newA) {
      return oldA.size() == 0
        || (oldA.size() == 1 && approvalEntryPreserved(oldA[0], newA[0]))
        || (oldA.size() == 2
            && approvalEntryPreserved(oldA[0], newA[0])
            && approvalEntryPreserved(oldA[1], newA[1]));
    }

    // Approvals array may keep the same length (content edit or in-place
    // invalidation flip, with identity preserved via noApprovalTampering)
    // OR grow by exactly one entry authored by the bishopric member
    // performing the write. Shrinking and foreign-author appends are
    // rejected. Duplicate prevention is client-enforced.
    function approvalsArrayOk(wardId) {
      let oldApprovals = resource.data.get('approvals', []);
      let newApprovals = request.resource.data.get('approvals', []);
      let lastIdx = newApprovals.size() - 1;
      return (newApprovals.size() == oldApprovals.size()
              && noApprovalTampering(oldApprovals, newApprovals))
        || (newApprovals.size() == oldApprovals.size() + 1
            && isActiveBishopric(wardId)
            && newApprovals[lastIdx].uid == request.auth.uid
            && newApprovals[lastIdx].invalidated == false
            && noApprovalTampering(oldApprovals, newApprovals));
    }

    match /wards/{wardId} {
      allow read: if isActiveMember(wardId);
      // Settings live on the ward doc; only bishopric can change them.
      allow update: if isActiveBishopric(wardId);
      // Ward creation/deletion is Admin-SDK-only (see scripts/bootstrap-ward.ts).
      allow create, delete: if false;

      // Per-doc (get) + list access for members in a specific ward.
      match /members/{memberId} {
        allow read: if isActiveMember(wardId);
        // Only an existing active bishopric member can mutate the roster.
        // With no active bishopric in a ward, non-admin creates are blocked
        // -- the Admin SDK seeds the first member.
        allow create, delete: if isActiveBishopric(wardId);
        // Roster updates are bishopric-only OR self-edits limited to a
        // member's own notification prefs and FCM tokens (so a clerk can
        // toggle quiet hours / register a device without touching role).
        allow update: if isActiveBishopric(wardId)
          || (isActiveMember(wardId)
              && request.auth.uid == memberId
              && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['notificationPrefs', 'fcmTokens', 'updatedAt']));
      }

      // Meetings and their speaker subcollection. Content edits are open to
      // any active member. Approval transitions (status pending_approval /
      // approved, growing the approvals array) are gated to bishopric.
      match /meetings/{date} {
        allow read: if isActiveMember(wardId);
        allow create, delete: if isActiveMember(wardId);
        allow update: if isActiveMember(wardId)
          && statusTransitionOk(wardId)
          && approvalsArrayOk(wardId);

        match /speakers/{speakerId} {
          allow read: if isActiveMember(wardId);
          allow create, update, delete: if isActiveMember(wardId);
        }

        // Comments: any active member reads + creates (with authorUid tied
        // to the caller). Authors own their edits/soft-deletes; no one else
        // can mutate. authorUid on create MUST match request.auth.uid so a
        // malicious client can't impersonate another member.
        match /comments/{commentId} {
          allow read: if isActiveMember(wardId);
          allow create: if isActiveMember(wardId)
            && request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if isActiveMember(wardId)
            && resource.data.authorUid == request.auth.uid;
        }

        // History (audit trail): write-once log appended in the same batch as
        // the underlying content change. Any active member reads. Creates
        // require actorUid to match the caller and the standard event shape.
        // No updates or deletes -- audit history is immutable.
        match /history/{eventId} {
          allow read: if isActiveMember(wardId);
          allow create: if isActiveMember(wardId)
            && request.resource.data.actorUid == request.auth.uid
            && request.resource.data.target in ['meeting', 'speaker', 'comment', 'approval']
            && request.resource.data.action in ['create', 'update', 'delete'];
          allow update, delete: if false;
        }
      }

    }

    // Cross-ward allowlist query: any signed-in user can read a member doc
    // whose email matches their Google-verified email. This satisfies the
    // sign-in collectionGroup('members').where('email','==',auth.email)
    // lookup without letting them read unrelated members. The client must
    // filter on email for Firestore to consider the list query safe.
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn() && resource.data.email == userEmail();
    }

    // Deny-all baseline for every other path; permissions land in later phases.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
