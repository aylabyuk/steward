# Firebase web app config (Project Settings -> Your apps -> Web app -> SDK snippet)
# Copy this file to .env.local and fill in the values from your Firebase project.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: public VAPID key for FCM Web Push (Project Settings -> Cloud Messaging -> Web Push certificates).
# Only needed when Phase 13 (subscribe flow) lands.
VITE_FIREBASE_VAPID_KEY=

# Set to "true" to point the SDK at the local emulator suite instead of real Firebase.
# Useful for local dev + CI. Leave blank in production.
VITE_USE_EMULATORS=
