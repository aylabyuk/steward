# functions/.secret.local — overrides for firebase-functions defineSecret()
# values when running against the Firebase emulator. Gitignored.
#
# Copy to functions/.secret.local and fill in. Pull values from Firebase
# Secret Manager on the prod project:
#
#   firebase functions:secrets:access TWILIO_ACCOUNT_SID --project steward-prod-65a36
#   firebase functions:secrets:access TWILIO_AUTH_TOKEN --project steward-prod-65a36
#   firebase functions:secrets:access TWILIO_API_KEY_SID --project steward-prod-65a36
#   firebase functions:secrets:access TWILIO_API_KEY_SECRET --project steward-prod-65a36
#   firebase functions:secrets:access TWILIO_CONVERSATIONS_SERVICE_SID --project steward-prod-65a36
#   firebase functions:secrets:access TWILIO_FROM_NUMBER --project steward-prod-65a36

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_CONVERSATIONS_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_FROM_NUMBER_TESTING=
