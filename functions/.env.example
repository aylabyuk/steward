# functions/.env.local — non-secret runtime vars for the Firebase emulator.
# Loaded in addition to .env.<project-id>. Gitignored.
#
# Copy this file to functions/.env.local and fill in the two values below.
# Put the Twilio credentials in functions/.secret.local instead — Firebase
# treats defineSecret() values separately from defineString() env vars.

# Origin used by Cloud Functions to build invite URLs. Keep in sync with
# the vite dev port (default 5173).
STEWARD_ORIGIN=http://localhost:5173

# Stubs Twilio Messaging (SMS) only: when "true", sendSmsDirect logs the
# body + invite URL and returns a fake SID instead of calling Twilio.
# Conversations (chat JWTs, participants) always uses real Twilio.
STEWARD_DEV_STUB_SMS=true

# Comma-separated email allowlist for the dev-mode "use testing
# number" callable. Empty by default — leave blank in production
# unless a maintainer needs to route through TWILIO_FROM_NUMBER_TESTING.
DEV_MODE_EMAILS=

# Set to "true" to enforce Firebase App Check on the issueSpeakerSession
# callable. Roll out: deploy with the client-side site key set + this
# unset, observe `appCheckTokenInvalid` / `appCheckTokenMissing` metrics
# in the Firebase Console for a soak window, then flip to "true" once
# real traffic looks healthy. Leave blank in dev/emulator.
APP_CHECK_ENFORCED=

# ---- See functions/.secret.local.example for the Twilio credential keys.
